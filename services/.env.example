# SEO API Configuration
# Copy to .env and fill in your keys

# Primary provider: "semrush" (recommended) or "ahrefs"
SEO_API_PROVIDER=semrush

# SEMrush API key (from semrush.com > Subscription Info > API units)
SEMRUSH_API_KEY=

# Ahrefs API key (from ahrefs.com > Account settings > API keys)
AHREFS_API_KEY=

# Request timeout in milliseconds (default: 10000)
SEO_API_TIMEOUT=10000

# --- Email Service ---
# Provider: "resend" (default) or "smtp"
EMAIL_PROVIDER=resend

# Resend API key (from resend.com/api-keys)
RESEND_API_KEY=

# Sender address
EMAIL_FROM=onboarding@ai1stseo.com

# SMTP settings (only if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Storage Paths (defaults work for local dev) ---
# SUBSCRIBER_STORE_PATH=./data/subscribers.json
# ANALYTICS_STORE_PATH=./data/analytics_events.json
# DASHBOARD_REPORT_PATH=./data/dashboard_report.json
# SCHEDULE_STORE_PATH=./data/social_schedule.json
# ENGAGEMENT_STORE_PATH=./data/engagement.json
