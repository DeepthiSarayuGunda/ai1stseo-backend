# ============================================
# AEO Platform — Environment Configuration
# ============================================

# --- App ---
PORT=3000
FLASK_DEBUG=false

# --- AI Routing (Nova Lite primary, Ollama fallback) ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
OLLAMA_ENDPOINT=https://ollama.sageaios.com/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# --- Free Search (no API key needed) ---
USE_FREE_SEARCH=true

# --- Optional: Paid Search APIs ---
BRAVE_API_KEY=
SERPER_API_KEY=

# --- AI Lab Provider Keys (optional) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# --- DynamoDB Migration (GEO Scanner + AEO Month 1 only) ---
# Set to 'true' to route AEO reports to DynamoDB instead of SQLite
USE_DYNAMO_AEO=false
# Set to 'true' to persist GEO scans to DynamoDB
USE_DYNAMO_GEO=false
# Set to 'true' to use DynamoDB for AI Business Directory
USE_DYNAMO_DIRECTORY=false
# Optional prefix for DynamoDB table names (e.g. 'dev-' → 'dev-aeo-reports')
DYNAMO_TABLE_PREFIX=
